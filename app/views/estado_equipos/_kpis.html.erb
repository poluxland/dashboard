<!-- app/views/estado_equipos/_kpis.html.erb -->
<div class="kpi-row">
  <div class="kc">
    <div class="kc-label">Score general zona</div>
    <div class="kc-value blue"><%= promedio_general %>%</div>
    <div class="kc-sub">
      <%= promedio_general >= 76 ? "Zona en buen estado" : promedio_general >= 51 ? "Suficiente bajo seguimiento" : promedio_general >= 26 ? "Condición con observaciones" : "Condición crítica" %>
    </div>
    <div class="kc-bar">
      <div class="kc-bar-fill" style="width:<%= promedio_general %>%;background:#378ADD"></div>
    </div>
  </div>

  <div class="kc">
    <div class="kc-label">Inspecciones registradas</div>
    <div class="kc-value blue"><%= total %></div>
    <div class="kc-sub">Registros acumulados en Molino 22</div>
  </div>

  <div class="kc">
    <div class="kc-label">Tiempo inspección</div>
    <div class="kc-value blue">2h 47m</div>
    <div class="kc-sub">70 componentes · turno A</div>
  </div>

  <div class="kc">
    <div class="kc-label">Cobertura inspector</div>
    <div class="kc-value green">100%</div>
    <div class="kc-sub">Área principal completada · demo</div>
    <div class="kc-bar">
      <div class="kc-bar-fill" style="width:100%;background:#639922"></div>
    </div>
  </div>
</div>

<style>
.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 18px;
}

.kc {
  background: #fff;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 14px;
  padding: 14px 16px;
}

.kc-label {
  font-size: 12px;
  color: #5F5E5A;
  margin-bottom: 6px;
}

.kc-value {
  font-size: 28px;
  font-weight: 700;
  line-height: 1;
}

.kc-value.blue {
  color: #185FA5;
}

.kc-value.red {
  color: #A32D2D;
}

.kc-value.green {
  color: #3B6D11;
}

.kc-sub {
  margin-top: 6px;
  font-size: 11px;
  color: #8A8882;
}

.kc-bar {
  width: 100%;
  height: 7px;
  background: #e9edf3;
  border-radius: 999px;
  overflow: hidden;
  margin-top: 10px;
}

.kc-bar-fill {
  height: 100%;
  border-radius: 999px;
}

@media (max-width: 900px) {
  .kpi-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 600px) {
  .kpi-row {
    grid-template-columns: 1fr;
  }
}
</style>