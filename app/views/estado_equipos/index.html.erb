<% content_for :title, "Estado equipos" %>

<%
  registros = @estado_equipos.order(created_at: :desc)

  def score_equipo(estado_equipo)
    valores = [
      estado_equipo.estado_cinta,
      estado_equipo.estado_motor,
      estado_equipo.estado_polines,
      estado_equipo.estado_ruedas,
      estado_equipo.estado_capachos,
      estado_equipo.estado_sistema_aire,
      estado_equipo.estado_filtro,
      estado_equipo.estado_estructura,
      estado_equipo.estado_lubricacion,
      estado_equipo.estado_limpieza
    ].compact.map(&:to_f)

    return nil if valores.empty?
    (valores.sum / valores.size).round
  end

  total = registros.count
  con_score = registros.map { |r| score_equipo(r) }.compact
  promedio_general = con_score.any? ? (con_score.sum.to_f / con_score.size).round : 0
  criticos = con_score.count { |s| s <= 25 }
  malos = con_score.count { |s| s > 25 && s <= 50 }
  suficientes = con_score.count { |s| s > 50 && s <= 75 }
  ok = con_score.count { |s| s > 75 }
%>

<style>
  :root {
    --navy: #0C447C;
    --blue: #185FA5;
    --blue-lt: #E6F1FB;
    --green: #3B6D11;
    --green-lt: #EAF3DE;
    --amber: #854F0B;
    --amber-lt: #FAEEDA;
    --red: #A32D2D;
    --red-lt: #FCEBEB;
    --text: #1a1a2e;
    --text-2: #5F5E5A;
    --text-3: #8A8882;
    --bg: #F4F6F9;
    --surface: #ffffff;
    --border: rgba(0,0,0,0.08);
    --radius: 12px;
  }

  body {
    background: var(--bg);
  }

  .estado-wrap {
    padding: 20px;
  }

  .estado-topbar {
    background: var(--navy);
    color: white;
    border-radius: 14px;
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    margin-bottom: 16px;
  }

  .estado-title {
    font-size: 24px;
    font-weight: 700;
    margin: 0;
  }

  .estado-subtitle {
    font-size: 13px;
    opacity: 0.75;
    margin-top: 4px;
  }

  .estado-actions a {
    text-decoration: none;
  }

  .estado-kpis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 18px;
  }

  .estado-kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
  }

  .estado-kpi-label {
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 6px;
  }

  .estado-kpi-value {
    font-size: 28px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
  }

  .estado-kpi-sub {
    margin-top: 6px;
    font-size: 11px;
    color: var(--text-3);
  }

  .estado-section-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin: 18px 0 10px;
  }

  .estado-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .estado-empty {
    background: white;
    border: 1px dashed rgba(0,0,0,0.15);
    border-radius: 12px;
    padding: 24px;
    color: var(--text-2);
  }

  @media (max-width: 900px) {
    .estado-kpis {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .estado-topbar {
      flex-direction: column;
      align-items: flex-start;
    }

    .estado-kpis {
      grid-template-columns: 1fr;
    }
  }

  
</style>

<div class="estado-wrap">
  <%= render "topbar",
    criticos: criticos,
    malos: malos,
    suficientes: suficientes,
    ok: ok,
    total: total %>

  <%= render "kpis",
    total: total,
    promedio_general: promedio_general %>

  <div class="estado-section-title">Hallazgos y estados registrados</div>

  <% if registros.any? %>
    <div class="estado-list">
      <% registros.each do |estado_equipo| %>
        <%= render "estado_card", estado_equipo: estado_equipo %>
      <% end %>
    </div>
  <% else %>
    <%= render "empty_state" %>
  <% end %>
</div>